# SCHOOLME101 MCP Server — Environment Configuration
# Copy this file to .env and fill in your values

# Server mode: 'stdio' for Claude Desktop / OpenClaw, 'http' for web integration
MCP_TRANSPORT=stdio

# HTTP transport port (only used when MCP_TRANSPORT=http)
PORT=3000

# Log level: 'error' | 'warn' | 'info' | 'debug'
LOG_LEVEL=info

# Path to curriculum markdown files (defaults to repository root)
CURRICULUM_PATH=.
