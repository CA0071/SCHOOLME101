# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/schoolmate101
DB_HOST=localhost
DB_PORT=5432
DB_NAME=schoolmate101
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# AI / Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=your-openai-api-key-optional

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=150

# Vector Search
EMBEDDING_DIMENSIONS=768
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
