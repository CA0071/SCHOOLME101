{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schoolme101.local/schemas/catalog.schema.json",
  "title": "SCHOOLME101 Knowledgebase Catalog",
  "type": "object",
  "required": ["version", "entries"],
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_from": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "grade", "grade_band", "subject", "source_path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "grade": { "type": "string", "pattern": "^Grade (R|[1-9]|1[0-2])$" },
          "grade_band": {
            "type": "string",
            "enum": ["Foundation Phase", "Intermediate Phase", "Senior Phase", "FET Phase"]
          },
          "subject": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "pattern": "^[^/].*\\.md$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
